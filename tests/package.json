{
  "name": "camiloavila-dev-tests",
  "version": "1.0.0",
  "description": "E2E test dependencies for camiloavila.dev — Cypress and Puppeteer",
  "private": true,
  "scripts": {
    "test:cypress": "cypress run --config-file tests/e2e/cypress/cypress.config.ts",
    "test:cypress:open": "cypress open --config-file tests/e2e/cypress/cypress.config.ts",
    "test:puppeteer": "jest --config tests/e2e/puppeteer/jest.config.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "cypress": "^13.12.0",
    "cypress-mochawesome-reporter": "^3.8.2",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "puppeteer": "^22.12.1",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
