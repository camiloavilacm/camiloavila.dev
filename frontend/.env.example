# =============================================================================
# frontend/.env.example
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is listed in .gitignore.
#
# In CI/CD, VITE_API_URL is passed as an environment variable in deploy.yml
# using the API Gateway URL output from `sam deploy`.
#
# How to find your API Gateway URL after first deploy:
#   aws cloudformation describe-stacks \
#     --stack-name camiloavila-dev \
#     --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" \
#     --output text
# =============================================================================

# API Gateway base URL (no trailing slash)
# Local development (sam local start-api on port 3000):
VITE_API_URL=http://localhost:3000

# Production example (replace with your actual API Gateway URL after deploy):
# VITE_API_URL=https://abc123.execute-api.us-east-1.amazonaws.com/prod
